        }
        lines {
          text: "    const numericAmount = parseFloat(invoiceAmount);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const revStr = erpState.kpis.totalRevenue.value.replace(\"$\", \"\").replace(\"M\", \"\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const currentRev = parseFloat(revStr);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const addedRevM = numericAmount / 1000000;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const updatedRev = `$${(currentRev + addedRevM).toFixed(2)}M`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
