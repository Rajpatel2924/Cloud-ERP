        }
        lines {
          text: "    const currentExp = parseFloat(expStr);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const updatedProfit = `$${((currentRev + addedRevM) - currentExp).toFixed(2)}M`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
